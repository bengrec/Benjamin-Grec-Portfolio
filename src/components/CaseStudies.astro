---
import { site } from '@data/site';
import ProjectCard from './ProjectCard.astro';
import { Icon } from 'astro-icon/components';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const archiveHref = `${base}projects`;
---

<section
  id="case-studies"
  class="mb-24 scroll-mt-24 lg:mb-32 lg:scroll-mt-8"
  aria-labelledby="case-studies-heading"
>
  <h2 id="case-studies-heading" class="section-heading">Case Studies</h2>
  <div class="space-y-20">
    {site.caseStudies.map((study) => (
      <ProjectCard
        project={study}
        imageSrc={study.image ? `${base}${study.image}` : undefined}
      />
    ))}
  </div>
  <p class="mt-14">
    <a
      href={archiveHref}
      class="group flex items-center gap-2 text-sm text-accent transition hover:text-subtext"
      data-astro-prefetch
    >
      View Full Project Archive
      <Icon name="ph:arrow-right" class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" />
    </a>
  </p>
</section>
